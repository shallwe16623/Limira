def _require_enterprise_file_user(user: LimiraUser) -> None:
    if user.account_type != "enterprise" or not user.organization_id:
        raise HTTPException(status_code=403, detail="enterprise_cloud_storage_required")


def _enterprise_user_storage_quota_bytes() -> int:
    raw_value = os.getenv(
        LIMIRA_ENTERPRISE_USER_STORAGE_QUOTA_BYTES_ENV,
        str(LIMIRA_DEFAULT_ENTERPRISE_USER_STORAGE_QUOTA_BYTES),
    )
    try:
        quota = int(raw_value)
    except (TypeError, ValueError):
        quota = LIMIRA_DEFAULT_ENTERPRISE_USER_STORAGE_QUOTA_BYTES
    return max(0, quota)


def _cloud_storage_documents(
    repo: LimiraTaskRepository,
    *,
    owner_user_id: str,
) -> list[LimiraUploadedDocument]:
    return [
        document
        for document in repo.list_user_documents(owner_user_id=owner_user_id)
        if not document.task_id
        and not (document.metadata or {}).get("source_document_id")
    ]


def _unique_document_storage_bytes(documents: list[LimiraUploadedDocument]) -> int:
    counted: set[str] = set()
    total = 0
    for document in documents:
        key = document.object_key or document.document_id
        if key in counted:
            continue
        counted.add(key)
        total += max(0, int(document.byte_size or 0))
    return total


def _enterprise_storage_payload(
    repo: LimiraTaskRepository,
    user: LimiraUser,
) -> dict[str, Any]:
    _require_enterprise_file_user(user)
    documents = repo.list_user_documents(owner_user_id=user.id)
    used_bytes = _unique_document_storage_bytes(documents)
    quota_bytes = _enterprise_user_storage_quota_bytes()
    return {
        "used_bytes": used_bytes,
        "quota_bytes": quota_bytes,
        "remaining_bytes": max(0, quota_bytes - used_bytes),
        "usage_ratio": round(used_bytes / quota_bytes, 6) if quota_bytes else 1,
    }


def _ensure_enterprise_storage_capacity(
    repo: LimiraTaskRepository,
    user: LimiraUser,
    *,
    incoming_bytes: int,
) -> None:
    payload = _enterprise_storage_payload(repo, user)
    if payload["used_bytes"] + max(0, int(incoming_bytes or 0)) > payload["quota_bytes"]:
        raise HTTPException(status_code=413, detail="enterprise_cloud_storage_quota_exceeded")


def _enterprise_cloud_storage_enabled(user: LimiraUser) -> bool:
    return user.account_type == "enterprise" and bool(user.organization_id)


def _generated_cloud_document_id(
    *,
    owner_user_id: str,
    object_key: str,
) -> str:
    return str(uuid.uuid5(uuid.NAMESPACE_URL, f"limira-cloud:{owner_user_id}:{object_key}"))


def _record_generated_cloud_document(
    repo: LimiraTaskRepository,
    user: LimiraUser,
    *,
    task: LimiraTask,
    stored: LimiraStoredObject,
    filename: str,
    extracted_text: str,
    metadata: Mapping[str, Any],
) -> LimiraUploadedDocument | None:
    if not _enterprise_cloud_storage_enabled(user):
        return None
    document_id = _generated_cloud_document_id(
        owner_user_id=user.id,
        object_key=stored.object_key,
    )
    existing = repo.get_user_document(document_id, user.id)
    incoming_bytes = max(
        0,
        int(stored.size_bytes or 0) - int(existing.byte_size if existing else 0),
    )
    _ensure_enterprise_storage_capacity(repo, user, incoming_bytes=incoming_bytes)
    document = repo.record_uploaded_document(
        document_id=document_id,
        owner_user_id=user.id,
        task_id=None,
        original_filename=_safe_original_filename(filename),
        content_type=stored.content_type,
        byte_size=stored.size_bytes,
        minio_bucket=stored.bucket,
        object_key=stored.object_key,
        extracted_text=extracted_text,
        language=None,
        metadata={
            "sha256": stored.sha256,
            "upload_source": "generated_task_asset",
            "source_task_id": task.task_id,
            **dict(metadata),
        },
        embedding=None,
    )
    return document


def _try_record_generated_cloud_document(
    repo: LimiraTaskRepository,
    user: LimiraUser,
    *,
    task: LimiraTask,
    stored: LimiraStoredObject,
    filename: str,
    extracted_text: str,
    metadata: Mapping[str, Any],
) -> LimiraUploadedDocument | None:
    try:
        return _record_generated_cloud_document(
            repo,
            user,
            task=task,
            stored=stored,
            filename=filename,
            extracted_text=extracted_text,
            metadata=metadata,
        )
    except Exception:
        log.exception(
            "Limira generated asset cloud registration failed for task_id=%s",
            task.task_id,
        )
        return None


def _normalize_research_document_ids(document_ids: list[str]) -> list[str]:
    normalized: list[str] = []
    seen: set[str] = set()
    for raw_document_id in document_ids or []:
        document_id = str(raw_document_id or "").strip()
        if not document_id or document_id in seen:
            continue
        if len(document_id) > 120:
            raise HTTPException(status_code=400, detail="invalid_document_id")
        seen.add(document_id)
        normalized.append(document_id)
    if len(normalized) > 20:
        raise HTTPException(status_code=400, detail="too_many_documents")
    return normalized


def _owned_documents_for_research(
    repo: LimiraTaskRepository,
    user: LimiraUser,
    document_ids: list[str],
) -> list[LimiraUploadedDocument]:
    normalized_ids = _normalize_research_document_ids(document_ids)
    if not normalized_ids:
        return []
    _require_enterprise_file_user(user)
    documents: list[LimiraUploadedDocument] = []
    for document_id in normalized_ids:
        document = repo.get_user_document(document_id, user.id)
        if document is None:
            raise HTTPException(status_code=404, detail="document_not_found")
        documents.append(document)
    return documents


def _attach_documents_to_task(
    repo: LimiraTaskRepository,
    *,
    task_id: str,
    user: LimiraUser,
    documents: list[LimiraUploadedDocument],
) -> list[LimiraUploadedDocument]:
    attached: list[LimiraUploadedDocument] = []
    for document in documents:
        metadata = {
            **(document.metadata or {}),
            "attachment_source": "history",
            "source_document_id": document.document_id,
        }
        attached.append(
            repo.record_uploaded_document(
                document_id=str(uuid.uuid4()),
                owner_user_id=user.id,
                task_id=task_id,
                original_filename=document.original_filename,
                content_type=document.content_type,
                byte_size=document.byte_size,
                minio_bucket=document.minio_bucket,
                object_key=document.object_key,
                extracted_text=document.extracted_text,
                language=document.language,
                metadata=metadata,
                embedding=document.embedding,
            )
        )
    return attached


def _upload_source_document_id(document: LimiraUploadedDocument) -> str:
    metadata = document.metadata or {}
    source_document_id = str(metadata.get("source_document_id") or "").strip()
    return source_document_id or document.document_id


def _upload_document_text(document: LimiraUploadedDocument) -> str:
    return str(document.extracted_text or "").strip()


def _upload_scope_retrieval_status(
    documents: list[LimiraUploadedDocument],
) -> str:
    if not documents:
        return "context_only"
    text_count = sum(1 for document in documents if _upload_document_text(document))
    if text_count == len(documents):
        return "retrieved"
    if text_count:
        return "partial"
    return "context_only"


def _upload_source_content_hash(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8", errors="replace")).hexdigest()


def _upload_source_candidate_id(
    task_id: str,
    document: LimiraUploadedDocument,
) -> str:
    source = f"{task_id}:{document.document_id}:{_upload_source_document_id(document)}"
    digest = hashlib.sha256(source.encode("utf-8", errors="replace")).hexdigest()[:12]
    return f"SRC-UPLOAD-{digest}"


def _upload_source_excerpt(text: str, *, max_chars: int = 4000) -> str:
    if len(text) <= max_chars:
        return text
    return text[:max_chars].rstrip()


def _upload_source_candidate_payload(
    *,
    task_id: str,
    document: LimiraUploadedDocument,
) -> dict[str, Any]:
    text = _upload_document_text(document)
    has_text = bool(text)
    source_document_id = _upload_source_document_id(document)
    status = "retrieved" if has_text else "context_only"
    content_state = "content_bearing" if has_text else "context_only"
    filename = document.original_filename or source_document_id
    payload: dict[str, Any] = {
        "candidate_id": _upload_source_candidate_id(task_id, document),
        "title": f"Uploaded document: {filename}",
        "summary": _upload_source_excerpt(text, max_chars=800)
        if has_text
        else "Uploaded document is attached as context only; extracted text is unavailable.",
        "source_type": "limira_upload",
        "source_state": "source_candidate",
        "source_content_state": content_state,
        "retrieval_status": status,
        "candidate": True,
        "document_id": source_document_id,
        "attached_document_id": document.document_id,
        "filename": filename,
        "content_type": document.content_type,
        "byte_size": document.byte_size,
        "language": document.language,
        "source_event_type": "limira_upload_attachment",
        "confidence": 0.55 if has_text else 0.1,
    }
    if has_text:
        excerpt = _upload_source_excerpt(text)
        payload.update(
            {
                "text": excerpt,
                "snippet": _upload_source_excerpt(text, max_chars=800),
                "text_char_count": len(text),
                "text_truncated": len(excerpt) < len(text),
                "content_hash": _upload_source_content_hash(text),
                "retrieved_at": _history_timestamp(),
            }
        )
    return {key: value for key, value in payload.items() if value is not None}


def _record_upload_source_artifacts(
    repo: LimiraTaskRepository,
    *,
    task_id: str,
    documents: list[LimiraUploadedDocument],
) -> None:
    for document in documents:
        repo.record_artifact(
            task_id,
            "source_candidate",
            _upload_source_candidate_payload(task_id=task_id, document=document),
        )


def _runner_upload_source_payloads(
    *,
    task_id: str,
    documents: list[LimiraUploadedDocument],
) -> list[dict[str, Any]]:
    payloads: list[dict[str, Any]] = []
    for document in documents:
        text = _upload_document_text(document)
        if not text:
            continue
        candidate = _upload_source_candidate_payload(task_id=task_id, document=document)
        excerpt = _upload_source_excerpt(
            text,
            max_chars=RUNNER_UPLOAD_SOURCE_TEXT_MAX_CHARS,
        )
        payloads.append(
            {
                "candidate_id": candidate["candidate_id"],
                "document_id": candidate["document_id"],
                "attached_document_id": candidate["attached_document_id"],
                "filename": candidate["filename"],
                "source_type": candidate["source_type"],
                "source_state": candidate["source_state"],
                "source_content_state": candidate["source_content_state"],
                "retrieval_status": candidate["retrieval_status"],
                "snippet": _upload_source_excerpt(excerpt, max_chars=800),
                "text": excerpt,
                "text_char_count": candidate["text_char_count"],
                "text_truncated": candidate["text_char_count"] > len(excerpt),
                "content_hash": candidate["content_hash"],
                "retrieved_at": candidate["retrieved_at"],
            }
        )
        if len(payloads) >= RUNNER_UPLOAD_SOURCE_PAYLOAD_MAX_ITEMS:
            break
    return payloads


def _runner_upload_scope_for_documents(
    source_documents: list[LimiraUploadedDocument],
    attached_documents: list[LimiraUploadedDocument],
) -> dict[str, Any]:
    retrieved_document_ids = [
        _upload_source_document_id(document)
        for document in attached_documents
        if _upload_document_text(document)
    ]
    context_only_document_ids = [
        _upload_source_document_id(document)
        for document in attached_documents
        if not _upload_document_text(document)
    ]
    return {
        "source_type": "limira_upload",
        "document_ids": [document.document_id for document in source_documents],
        "attached_document_ids": [document.document_id for document in attached_documents],
        "document_count": len(source_documents),
        "retrieval_status": _upload_scope_retrieval_status(attached_documents),
        "retrieved_document_ids": retrieved_document_ids,
        "context_only_document_ids": context_only_document_ids,
        "source_payloads": _runner_upload_source_payloads(
            task_id=str(attached_documents[0].task_id or "")
            if attached_documents
            else "",
            documents=attached_documents,
        ),
    }


def _runner_source_policy(
    *,
    scenario: str | None,
    documents: list[LimiraUploadedDocument],
) -> dict[str, Any]:
    return {
        "min_sources": 3,
        "prefer_primary_sources": True,
        "allow_secondary_sources": True,
        "require_retrieved_at": True,
        "prefer_uploaded_documents": bool(documents),
        "prefer_scenario_sources": bool(scenario),
    }


@router.post("/speech/transcribe")
async def transcribe_speech_audio(
    file: UploadFile,
    language: str | None = Form(default=None),
    user: LimiraUser = Depends(get_current_limira_user),
) -> dict[str, Any]:
    filename = _safe_original_filename(file.filename or "voice.webm")
    content_type = _speech_audio_content_type(file.content_type, filename)
    try:
        await file.seek(0)
    except Exception:
        pass
    data = await file.read()
    if not data:
        raise HTTPException(status_code=400, detail="empty_audio_upload")
    max_bytes = _speech_max_audio_bytes()
    if len(data) > max_bytes:
        raise HTTPException(status_code=413, detail="speech_audio_too_large")
    result = await asyncio.to_thread(
        _transcribe_speech_audio,
        data,
        filename=filename,
        content_type=content_type,
        language=language,
    )
    return _assert_browser_safe(
        {
            "text": result["text"],
            "language": result.get("language"),
            "duration_seconds": result.get("duration_seconds"),
            "content_type": content_type,
            "filename": filename,
            "user_authenticated": bool(user.id),
        }
    )


