# Limira runner local development
RUNNER_SERVICE_TOKEN=
LIMIRA_RUNNER_INTERNAL_PORT=8091

# Main model endpoint used by the agent.
BASE_URL=
API_KEY=
DEFAULT_LLM_PROVIDER=qwen
DEFAULT_MODEL_NAME=Limira

# Search, scraping, and sandbox tools.
SERPER_API_KEY=
SERPER_BASE_URL=https://google.serper.dev
JINA_API_KEY=
JINA_BASE_URL=https://r.jina.ai
E2B_API_KEY=

# Optional summary model used by the scrape-and-extract tool.
SUMMARY_LLM_BASE_URL=
SUMMARY_LLM_MODEL_NAME=
SUMMARY_LLM_API_KEY=

# Optional persistent task store for direct runner development.
RUNNER_TASK_STORE_BACKEND=sqlite
RUNNER_ALLOW_SQLITE_TASK_STORE=true
RUNNER_SQLITE_PATH=runner_tasks.sqlite3
