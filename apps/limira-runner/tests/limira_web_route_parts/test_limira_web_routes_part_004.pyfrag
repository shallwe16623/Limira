                "payload": {
                    "event": "start_of_agent",
                    "data": {
                        "agent_name": "Final Summary",
                        "agent_id": "agent-final",
                    },
                },
            },
            {
                "task_id": "runner-task-a",
                "type": "tool_call",
                "payload": {
                    "event": "tool_call",
                    "data": {
                        "tool_name": "show_text",
                        "tool_input": {
                            "text": "# Nested final answer\n\nUse the final report. [EVID-777]"
                        },
                    },
                },
            },
            {
                "task_id": "runner-task-a",
                "type": "end_of_agent",
                "payload": {
                    "event": "end_of_agent",
                    "data": {
                        "agent_name": "Final Summary",
                        "agent_id": "agent-final",
                    },
                },
            },
        ]
    )

    created = await limira.create_research_task(
        {"query": "nested final summary"},
        request=None,
        user=user,
        repo=repo,
        research_client=research,
    )
