def test_show_text_markdown_formats_structured_report_json():
    structured_report = json.dumps(
        {
            "title": "2026年6月8日美国国防部1260H清单新增中国企业全面报告",
            "sections": [
                {
                    "heading": "事件背景",
                    "content": "美国国防部依据NDAA第1260H条更新中国军事企业名单。",
                },
                {
                    "heading": "新增企业",
                    "content": "除比亚迪外，还包括阿里巴巴、百度、宇树科技等。",
                },
            ],
        },
        ensure_ascii=False,
    )

    markdown = limira._show_text_markdown({"text": f"草稿标题\n{structured_report}"})

    assert markdown.startswith("# 2026年6月8日美国国防部1260H清单新增中国企业全面报告")
    assert "## 事件背景" in markdown
    assert "美国国防部依据NDAA第1260H条更新中国军事企业名单。" in markdown
    assert "## 新增企业" in markdown
    assert '{"title"' not in markdown
    assert '"sections"' not in markdown


