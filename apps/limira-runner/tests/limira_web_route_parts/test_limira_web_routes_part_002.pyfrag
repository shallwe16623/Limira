        endpoint_url="http://minio:9000",
        access_key_id="limira_minio",
        secret_access_key="replace-with-local-minio-password",
        s3_client=s3,
    )
    object_key = limira.build_limira_object_key(
        owner_user_id="user-a",
        category="archives",
        task_id="task-a",
        filename="archive.zip",
        object_id="archive-a",
    )

    stored = await storage.put_object(
        object_key=object_key,
        data=b"archive-bytes",
        content_type="application/zip",
        metadata={"task_id": "task-a", "none": None, "unsafe key": "value"},
    )

    assert stored.object_key == object_key
    assert stored.bucket == "limira-artifacts"
    assert stored.size_bytes == len(b"archive-bytes")
    assert stored.sha256
    assert stored.metadata == {"task_id": "task-a", "unsafe-key": "value"}
    assert s3.put_calls == [
        {
            "Bucket": "limira-artifacts",
            "Key": object_key,
            "Body": b"archive-bytes",
            "ContentType": "application/zip",
            "Metadata": {"task_id": "task-a", "unsafe-key": "value"},
        }
    ]


@pytest.mark.asyncio
async def test_upload_route_rejects_object_key_aliases_on_actual_http_surface():
    app, _repo, _storage = _limira_asgi_app()

    async with httpx.AsyncClient(
        transport=httpx.ASGITransport(app=app),
        base_url="http://limira.test",
    ) as client:
        assert set(PLAN_NAMED_OBJECT_KEY_ALIASES).issubset(
            limira.OBJECT_KEY_FORBIDDEN_FIELDS
        )
        aliases = sorted(
            set(limira.OBJECT_KEY_FORBIDDEN_FIELDS)
            | set(PLAN_NAMED_OBJECT_KEY_ALIASES)
        )
        for alias in aliases:
            query_response = await client.post(
                "/api/limira/uploads",
                params={alias: "users/user-a/uploads/evil.pdf"},
                files={"file": ("evidence.txt", b"evidence", "text/plain")},
            )
            assert query_response.status_code == 400, alias
            assert query_response.json()["detail"] == "object_key_server_generated"

            form_response = await client.post(
                "/api/limira/uploads",
                data={alias: "users/user-a/uploads/evil.pdf"},
                files={"file": ("evidence.txt", b"evidence", "text/plain")},
            )
            assert form_response.status_code == 400, alias
            assert form_response.json()["detail"] == "object_key_server_generated"

        empty_query_response = await client.post(
            "/api/limira/uploads",
            params={"object_key": ""},
            files={"file": ("evidence.txt", b"evidence", "text/plain")},
        )
        assert empty_query_response.status_code == 400
        assert empty_query_response.json()["detail"] == "object_key_server_generated"

        duplicate_query_response = await client.post(
            "/api/limira/uploads?object_key=users/user-a/uploads/evil.pdf&object_key=",
            files={"file": ("evidence.txt", b"evidence", "text/plain")},
        )
        assert duplicate_query_response.status_code == 400
        assert duplicate_query_response.json()["detail"] == "object_key_server_generated"

        empty_form_response = await client.post(
            "/api/limira/uploads",
            data={"object_key": ""},
            files={"file": ("evidence.txt", b"evidence", "text/plain")},
        )
        assert empty_form_response.status_code == 400
        assert empty_form_response.json()["detail"] == "object_key_server_generated"


@pytest.mark.asyncio
async def test_upload_route_stores_text_original_and_document_record():
    app, repo, storage = _limira_asgi_app()

    async with httpx.AsyncClient(
        transport=httpx.ASGITransport(app=app),
        base_url="http://limira.test",
    ) as client:
        response = await client.post(
            "/api/limira/uploads",
            files={"file": ("evidence.txt", b"hello limira", "text/plain")},
        )

    assert response.status_code == 201
    payload = response.json()
    assert payload["filename"] == "evidence.txt"
    assert payload["content_type"] == "text/plain"
    assert payload["byte_size"] == len(b"hello limira")
    assert payload["extracted_text_chars"] == len("hello limira")
    assert "object_key" not in payload
    assert "minio_object_key" not in payload

    document = repo.get_user_document(payload["document_id"], "user-a")
    assert document is not None
    assert document.owner_user_id == "user-a"
    assert document.task_id is None
    assert document.extracted_text == "hello limira"
    assert document.embedding is None
    assert document.metadata["embedding"] == {
        "enabled": False,
        "provider": "disabled",
        "model": "",
        "dimensions": 1536,
        "status": "disabled",
    }
    assert document.minio_bucket == storage.bucket
    assert document.object_key in storage.objects
    stored = storage.objects[document.object_key]
    assert stored["data"] == b"hello limira"
    assert stored["content_type"] == "text/plain"
    assert stored["metadata"]["document_id"] == document.document_id
    assert stored["metadata"]["owner_user_id"] == "user-a"
    _assert_no_browser_leak(payload)


@pytest.mark.asyncio
async def test_upload_route_rejects_active_or_unsupported_content_types():
    app, repo, storage = _limira_asgi_app()

    async with httpx.AsyncClient(
        transport=httpx.ASGITransport(app=app),
        base_url="http://limira.test",
    ) as client:
        for filename, content_type in [
            ("active.html", "text/html; charset=utf-8"),
            ("active.svg", "image/svg+xml"),
            ("active.xml", "application/xml"),
            ("active.js", "application/javascript"),
            ("unknown.bin", "application/octet-stream"),
        ]:
            response = await client.post(
                "/api/limira/uploads",
                files={
                    "file": (
                        filename,
                        b"<script>alert(1)</script>",
                        content_type,
                    )
                },
            )
            assert response.status_code == 415, (filename, content_type)
            assert response.json()["detail"] == "unsupported_upload_type"

        markdown_response = await client.post(
            "/api/limira/uploads",
            files={
                "file": (
                    "source.md",
                    b"# inert markdown",
                    "application/octet-stream",
                )
            },
        )

    assert markdown_response.status_code == 201
    assert markdown_response.json()["content_type"] == "text/markdown"
    assert len(repo.uploaded_documents) == 1
    assert len(storage.objects) == 1
    document = next(iter(repo.uploaded_documents.values()))
    assert document.original_filename == "source.md"
    assert document.content_type == "text/markdown"


@pytest.mark.asyncio
async def test_personal_users_cannot_use_cloud_file_storage():
    app, _repo, _storage = _limira_asgi_app()

    async def personal_user_override():
        return limira.LimiraUser("personal-user")

    app.dependency_overrides[limira.get_current_limira_user] = personal_user_override

    async with httpx.AsyncClient(
        transport=httpx.ASGITransport(app=app),
        base_url="http://limira.test",
    ) as client:
        list_response = await client.get("/api/limira/uploads")
        history_response = await client.get("/api/limira/uploads/history")
        storage_response = await client.get("/api/limira/uploads/storage")
        upload_response = await client.post(
            "/api/limira/uploads",
            files={"file": ("personal.txt", b"personal", "text/plain")},
        )

    for response in [list_response, history_response, storage_response, upload_response]:
        assert response.status_code == 403
        assert response.json()["detail"] == "enterprise_cloud_storage_required"


@pytest.mark.asyncio
async def test_enterprise_uploads_enforce_per_user_cloud_storage_quota(monkeypatch):
    monkeypatch.setenv(limira.LIMIRA_ENTERPRISE_USER_STORAGE_QUOTA_BYTES_ENV, "7")
    app, repo, storage = _limira_asgi_app()

    async with httpx.AsyncClient(
        transport=httpx.ASGITransport(app=app),
        base_url="http://limira.test",
    ) as client:
        first_response = await client.post(
            "/api/limira/uploads",
            files={"file": ("first.txt", b"12345", "text/plain")},
        )
        quota_response = await client.get("/api/limira/uploads/storage")
        second_response = await client.post(
            "/api/limira/uploads",
            files={"file": ("second.txt", b"123", "text/plain")},
        )

    assert first_response.status_code == 201
    assert quota_response.status_code == 200
    assert quota_response.json()["storage"] == {
        "used_bytes": 5,
        "quota_bytes": 7,
        "remaining_bytes": 2,
        "usage_ratio": round(5 / 7, 6),
    }
    assert second_response.status_code == 413
    assert second_response.json()["detail"] == "enterprise_cloud_storage_quota_exceeded"
    assert len(repo.uploaded_documents) == 1
    assert len(storage.objects) == 1


@pytest.mark.asyncio
async def test_research_can_attach_history_documents_without_duplicate_storage():
    repo = limira.InMemoryLimiraTaskRepository()
    research = FakeResearchClient()
    user = limira.LimiraUser(
        "user-a",
        account_type="enterprise",
        organization_id="org-a",
        organization_role="member",
    )
    source = repo.record_uploaded_document(
        document_id="doc-cloud",
        owner_user_id="user-a",
        task_id=None,
        original_filename="cloud.txt",
        content_type="text/plain",
        byte_size=11,
        minio_bucket="limira-artifacts",
        object_key="limira/users/hash/uploads/doc-cloud.txt",
        extracted_text="cloud memo",
        language=None,
        metadata={"sha256": "cloud-sha"},
    )

    payload = await limira.create_research_task(
        {"query": "use uploaded file", "document_ids": ["doc-cloud"]},
        request=None,
        user=user,
        repo=repo,
        research_client=research,
    )

    attached = repo.list_user_documents(owner_user_id="user-a", task_id=payload["task_id"])
    all_documents = repo.list_user_documents(owner_user_id="user-a")
    storage_payload = limira._enterprise_storage_payload(repo, user)

    assert payload["uploaded_documents"][0]["filename"] == "cloud.txt"
    assert [document.original_filename for document in attached] == ["cloud.txt"]
    assert attached[0].document_id != source.document_id
    assert attached[0].object_key == source.object_key
    assert attached[0].metadata["source_document_id"] == "doc-cloud"
    assert {document.document_id for document in all_documents} == {
        "doc-cloud",
        attached[0].document_id,
    }
    runner_call = research.create_calls[0]
    assert runner_call["conversation_id"] == payload["conversation_id"]
    assert runner_call["document_ids"] == ["doc-cloud"]
    runner_upload_scope = dict(runner_call["upload_scope"])
    runner_source_payloads = runner_upload_scope.pop("source_payloads")
    assert runner_upload_scope == {
        "source_type": "limira_upload",
        "document_ids": ["doc-cloud"],
        "attached_document_ids": [attached[0].document_id],
        "document_count": 1,
        "retrieval_status": "retrieved",
        "retrieved_document_ids": ["doc-cloud"],
        "context_only_document_ids": [],
    }
    assert len(runner_source_payloads) == 1
    runner_source_payload = runner_source_payloads[0]
    assert runner_source_payload["document_id"] == "doc-cloud"
    assert runner_source_payload["attached_document_id"] == attached[0].document_id
    assert runner_source_payload["source_type"] == "limira_upload"
    assert runner_source_payload["source_content_state"] == "content_bearing"
    assert runner_source_payload["retrieval_status"] == "retrieved"
    assert runner_source_payload["text"] == "cloud memo"
    assert runner_source_payload["snippet"] == "cloud memo"
    assert runner_source_payload["content_hash"]
    assert runner_source_payload["retrieved_at"]
    assert runner_call["source_policy"]["prefer_uploaded_documents"] is True
    assert runner_call["source_policy"]["prefer_primary_sources"] is True
    artifacts = repo.get_artifacts(payload["task_id"])
    candidate = artifacts["source_candidates"][0]
    assert candidate["candidate_id"].startswith("SRC-UPLOAD-")
    assert candidate["document_id"] == "doc-cloud"
    assert candidate["attached_document_id"] == attached[0].document_id
    assert candidate["filename"] == "cloud.txt"
    assert candidate["source_type"] == "limira_upload"
    assert candidate["source_state"] == "source_candidate"
    assert candidate["source_content_state"] == "content_bearing"
    assert candidate["retrieval_status"] == "retrieved"
    assert candidate["candidate"] is True
    assert candidate["snippet"] == "cloud memo"
    assert candidate["text"] == "cloud memo"
    assert candidate["text_char_count"] == len("cloud memo")
    assert candidate["text_truncated"] is False
    assert candidate["content_hash"]
    assert candidate["retrieved_at"]
    assert repo.get_artifact_trace_events(payload["task_id"])[0]["type"] == (
        "source_candidate_collected"
    )
    assert storage_payload["used_bytes"] == 11
    assert storage_payload["quota_bytes"] == limira.LIMIRA_DEFAULT_ENTERPRISE_USER_STORAGE_QUOTA_BYTES


@pytest.mark.asyncio
async def test_research_records_context_only_upload_candidate_when_text_unavailable():
    repo = limira.InMemoryLimiraTaskRepository()
    research = FakeResearchClient()
    user = limira.LimiraUser(
        "user-a",
        account_type="enterprise",
        organization_id="org-a",
        organization_role="member",
    )
    repo.record_uploaded_document(
        document_id="doc-empty",
        owner_user_id="user-a",
        task_id=None,
        original_filename="empty.pdf",
        content_type="application/pdf",
        byte_size=42,
        minio_bucket="limira-artifacts",
        object_key="limira/users/hash/uploads/doc-empty.pdf",
        extracted_text="",
        language=None,
        metadata={"sha256": "empty-sha"},
    )

    payload = await limira.create_research_task(
        {"query": "use empty uploaded file", "document_ids": ["doc-empty"]},
        request=None,
        user=user,
        repo=repo,
        research_client=research,
    )

    attached = repo.list_user_documents(owner_user_id="user-a", task_id=payload["task_id"])
    runner_call = research.create_calls[0]
    assert runner_call["document_ids"] == ["doc-empty"]
    assert runner_call["upload_scope"]["retrieval_status"] == "context_only"
    assert runner_call["upload_scope"]["retrieved_document_ids"] == []
    assert runner_call["upload_scope"]["context_only_document_ids"] == ["doc-empty"]
    assert runner_call["upload_scope"]["source_payloads"] == []
