def test_pdf_text_extractor_accepts_valid_pdf_bytes():
    from pypdf import PdfWriter

    output = io.BytesIO()
    writer = PdfWriter()
    writer.add_blank_page(width=72, height=72)
    writer.write(output)

    assert limira._extract_pdf_text(output.getvalue()) == ""


@pytest.mark.asyncio
async def test_speech_transcribe_route_uses_backend_whisper_transcriber(monkeypatch):
    app, _repo, _storage = _limira_asgi_app()
    calls = []

    def fake_transcribe(data, *, filename, content_type, language=None):
        calls.append(
            {
                "data": data,
                "filename": filename,
                "content_type": content_type,
                "language": language,
            }
        )
        return {
            "text": "这是转写后的研究问题",
            "language": "zh",
            "duration_seconds": 1.25,
        }

    monkeypatch.setattr(limira, "_transcribe_speech_audio", fake_transcribe)

    async with httpx.AsyncClient(
        transport=httpx.ASGITransport(app=app),
        base_url="http://limira.test",
    ) as client:
        response = await client.post(
            "/api/limira/speech/transcribe",
            data={"language": "zh-CN"},
            files={"file": ("voice.webm", b"webm audio bytes", "audio/webm")},
        )

    assert response.status_code == 200
    assert response.json() == {
        "text": "这是转写后的研究问题",
        "language": "zh",
        "duration_seconds": 1.25,
        "content_type": "audio/webm",
        "filename": "voice.webm",
        "user_authenticated": True,
    }
    assert calls == [
        {
            "data": b"webm audio bytes",
            "filename": "voice.webm",
            "content_type": "audio/webm",
            "language": "zh-CN",
        }
    ]


@pytest.mark.asyncio
async def test_speech_transcribe_route_rejects_non_audio_upload(monkeypatch):
    app, _repo, _storage = _limira_asgi_app()
    monkeypatch.setattr(
        limira,
        "_transcribe_speech_audio",
        lambda *_args, **_kwargs: {"text": "should not run"},
    )

