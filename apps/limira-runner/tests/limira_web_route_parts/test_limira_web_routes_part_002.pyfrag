    candidate = artifacts["source_candidates"][0]
    assert candidate["document_id"] == "doc-empty"
    assert candidate["attached_document_id"] == attached[0].document_id
    assert candidate["source_type"] == "limira_upload"
    assert candidate["source_content_state"] == "context_only"
    assert candidate["retrieval_status"] == "context_only"
    assert "content_hash" not in candidate
    assert "retrieved_at" not in candidate
    assert "text" not in candidate
    assert "extracted text is unavailable" in candidate["summary"]


