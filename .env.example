# limira local deployment
COMPOSE_PROJECT_NAME=limira

# Public/local ports. These intentionally avoid the conservative worktree defaults.
LIMIRA_BIND_ADDRESS=127.0.0.1
LIMIRA_WEB_PORT=3001
LIMIRA_RUNNER_PORT=8091
POSTGRES_PORT=5433
REDIS_PORT=6380
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# Browser-facing web/backend shell.
LIMIRA_API_BASE_URL=/api/limira
LIMIRA_RUNNER_INTERNAL_URL=http://limira-runner:8091
LIMIRA_AUTH_SECRET=
LIMIRA_PUBLIC_BASE_URL=https://limira-inc.com

# Auth email delivery. If SMTP is not configured, backend writes messages to
# LIMIRA_AUTH_EMAIL_OUTBOX_PATH for local/dev testing.
LIMIRA_AUTH_EMAIL_OUTBOX_PATH=
LIMIRA_AUTH_EMAIL_VERIFY_TTL_SECONDS=86400
LIMIRA_AUTH_PASSWORD_RESET_TTL_SECONDS=3600
LIMIRA_SMTP_HOST=
LIMIRA_SMTP_PORT=587
LIMIRA_SMTP_USERNAME=
LIMIRA_SMTP_PASSWORD=
LIMIRA_SMTP_FROM=
LIMIRA_SMTP_TLS=true

# Optional Google sign-in. Create an OAuth 2.0 Web client in Google Cloud and
# add https://your-domain.example/api/limira/auth/google/callback as an
# authorized redirect URI. Leave blank to hide Google sign-in.
LIMIRA_GOOGLE_OAUTH_CLIENT_ID=
LIMIRA_GOOGLE_OAUTH_CLIENT_SECRET=
LIMIRA_GOOGLE_OAUTH_REDIRECT_URI=

# Optional WeChat sign-in for a WeChat Open Platform Website App. Add
# https://your-domain.example/api/limira/auth/wechat/callback as the callback URL.
LIMIRA_WECHAT_OAUTH_APP_ID=
LIMIRA_WECHAT_OAUTH_APP_SECRET=
LIMIRA_WECHAT_OAUTH_REDIRECT_URI=

# Optional HTTPS reverse proxy for a standalone server run.
LIMIRA_DOMAIN=limira-inc.com
CADDY_ACME_EMAIL=admin@limira-inc.com
LIMIRA_FRONTEND_UPSTREAM=127.0.0.1:5173

# Required secrets are intentionally blank in this example; compose fails fast until set.
# Service-to-service auth. Use a long random value before running.
RUNNER_SERVICE_TOKEN=

# Postgres 16 + PostGIS + pgvector.
LIMIRA_REPOSITORY_BACKEND=postgres
LIMIRA_DATABASE_URL=
# Local tests may set LIMIRA_REPOSITORY_BACKEND=memory and
# LIMIRA_ALLOW_IN_MEMORY_REPOSITORY=true explicitly. Do not enable that in compose.
LIMIRA_ALLOW_IN_MEMORY_REPOSITORY=false
POSTGRES_DB=limira
POSTGRES_USER=limira
POSTGRES_PASSWORD=
DATABASE_URL=

# Redis runtime state.
REDIS_URL=redis://redis:6379/0
LIMIRA_RUNTIME_STATE_BACKEND=redis
LIMIRA_TASK_EVENT_STREAM_MAXLEN=2000
LIMIRA_ALLOW_IN_MEMORY_RUNTIME_STATE=false

# MinIO S3-compatible object storage.
LIMIRA_OBJECT_STORAGE_BACKEND=s3
LIMIRA_ALLOW_IN_MEMORY_OBJECT_STORAGE=false
LIMIRA_OBJECT_BUCKET=limira-artifacts
LIMIRA_OBJECT_KEY_PREFIX=limira
MINIO_ROOT_USER=limira_minio
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=limira-artifacts
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=limira_minio
AWS_SECRET_ACCESS_KEY=

# Limira runner model/search/scrape config.
RUNNER_TASK_STORE_BACKEND=postgres
RUNNER_DATABASE_URL=
# Local tests may set RUNNER_TASK_STORE_BACKEND=sqlite and
# RUNNER_ALLOW_SQLITE_TASK_STORE=true explicitly. Do not enable that in compose.
RUNNER_ALLOW_SQLITE_TASK_STORE=false
BASE_URL=https://api.deepseek.com
API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL_NAME=deepseek-v4-pro
LIMIRA_LLM_LENGTH_MAX_RETRIES=3
LIMIRA_LLM_LENGTH_RETRY_WAIT_SECONDS=2
SERPER_API_KEY=
SERPER_BASE_URL=https://google.serper.dev
JINA_API_KEY=
JINA_BASE_URL=https://r.jina.ai
E2B_API_KEY=

# Optional summary LLM config.
SUMMARY_LLM_BASE_URL=https://api.deepseek.com/chat/completions
SUMMARY_LLM_MODEL_NAME=deepseek-v4-pro
SUMMARY_LLM_API_KEY=

# Optional upload/retrieval embedding config.
LIMIRA_UPLOAD_EMBEDDINGS_ENABLED=false
LIMIRA_EMBEDDING_PROVIDER=disabled
LIMIRA_EMBEDDING_MODEL=
LIMIRA_EMBEDDING_DIMENSIONS=1536
EMBEDDING_PROVIDER=
EMBEDDING_MODEL_NAME=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
