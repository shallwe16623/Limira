# limra aggressive local deployment
COMPOSE_PROJECT_NAME=limra_aggressive

# Public/local ports. These intentionally avoid the conservative worktree defaults.
LIMRA_WEB_PORT=3001
LIMRA_RUNNER_PORT=8091
POSTGRES_PORT=5433
REDIS_PORT=6380
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# Browser-facing web/backend shell.
LIMRA_API_BASE_URL=/api/limra
LIMRA_RUNNER_INTERNAL_URL=http://limra-runner:8091

# Service-to-service auth. Replace with a long random value before running outside local dev.
RUNNER_SERVICE_TOKEN=replace-with-long-random-service-token

# Postgres 16 + PostGIS + pgvector.
LIMRA_REPOSITORY_BACKEND=postgres
LIMRA_DATABASE_URL=postgresql://limra:replace-with-local-postgres-password@postgres:5432/limra
# Local tests may set LIMRA_REPOSITORY_BACKEND=memory and
# LIMRA_ALLOW_IN_MEMORY_REPOSITORY=true explicitly. Do not enable that in compose.
LIMRA_ALLOW_IN_MEMORY_REPOSITORY=false
POSTGRES_DB=limra
POSTGRES_USER=limra
POSTGRES_PASSWORD=replace-with-local-postgres-password
DATABASE_URL=postgresql://limra:replace-with-local-postgres-password@postgres:5432/limra

# Redis runtime state.
REDIS_URL=redis://redis:6379/0
LIMRA_RUNTIME_STATE_BACKEND=redis
LIMRA_ALLOW_IN_MEMORY_RUNTIME_STATE=false

# MinIO S3-compatible object storage.
LIMRA_OBJECT_STORAGE_BACKEND=s3
LIMRA_ALLOW_IN_MEMORY_OBJECT_STORAGE=false
LIMRA_OBJECT_BUCKET=limra-artifacts
LIMRA_OBJECT_KEY_PREFIX=limra
MINIO_ROOT_USER=limra_minio
MINIO_ROOT_PASSWORD=replace-with-local-minio-password
MINIO_BUCKET=limra-artifacts
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=limra_minio
AWS_SECRET_ACCESS_KEY=replace-with-local-minio-password

# MiroThinker Runner model/search/scrape config.
RUNNER_TASK_STORE_BACKEND=postgres
RUNNER_DATABASE_URL=postgresql://limra:replace-with-local-postgres-password@postgres:5432/limra
# Local tests may set RUNNER_TASK_STORE_BACKEND=sqlite and
# RUNNER_ALLOW_SQLITE_TASK_STORE=true explicitly. Do not enable that in compose.
RUNNER_ALLOW_SQLITE_TASK_STORE=false
BASE_URL=
DEFAULT_LLM_PROVIDER=
DEFAULT_MODEL_NAME=
SERPER_API_KEY=
JINA_API_KEY=
E2B_API_KEY=

# Optional summary LLM config.
SUMMARY_LLM_PROVIDER=
SUMMARY_BASE_URL=
SUMMARY_MODEL_NAME=
SUMMARY_API_KEY=

# Optional upload/retrieval embedding config.
LIMRA_UPLOAD_EMBEDDINGS_ENABLED=false
LIMRA_EMBEDDING_PROVIDER=disabled
LIMRA_EMBEDDING_MODEL=
LIMRA_EMBEDDING_DIMENSIONS=1536
EMBEDDING_PROVIDER=
EMBEDDING_MODEL_NAME=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
